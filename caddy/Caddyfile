# Caddy reverse proxy — routes by Host header
# Sits behind Tailscale Funnel on port 443, so no TLS here.
:80 {
	@backend host ws.braceml.com
	handle @backend {
		reverse_proxy backend:8000 backend-cpu:8000 {
			lb_policy first
		}
	}

	@frontend host braceml.com baby-gator.tailea0e34.ts.net
	handle @frontend {
		reverse_proxy frontend:3000
	}

	# Fallback: send everything else to frontend
	handle {
		reverse_proxy frontend:3000
	}
}
